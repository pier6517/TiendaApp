APP_NAME="TiendaApp"
APP_ENV=local
APP_KEY=base64:GENERAR_CON_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8000

# ──────────────────────────────────────────
# BASE DE DATOS MySQL (Laragon usa puerto 3306)
# ──────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tienda_barrio
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────
# SANCTUM — Autenticación por tokens
# ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173

# ──────────────────────────────────────────
# FRONTEND URL (React + Vite corre en 5173)
# ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────
# SESIONES
# ──────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ──────────────────────────────────────────
# CACHE Y QUEUE
# ──────────────────────────────────────────
CACHE_STORE=database
QUEUE_CONNECTION=database

# ──────────────────────────────────────────
# LOGS
# ──────────────────────────────────────────
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────
# CORREO (para recuperación de contraseña)
# ──────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tiendabarrio.co"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────
# CONFIGURACIÓN DE LA TIENDA
# ──────────────────────────────────────────
TIENDA_NOMBRE="Mi Tienda de Barrio"
TIENDA_NIT="123456789-0"
TIENDA_TELEFONO="3001234567"
TIENDA_DIRECCION="Calle 10 # 5-20"
TIENDA_CIUDAD="Medellín"
TIENDA_MONEDA=COP
TIENDA_IVA=19
